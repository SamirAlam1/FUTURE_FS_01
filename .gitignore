# .gitignore — place this in both /frontend and /backend roots
# (or in the repo root to cover both)

# ── Environment files — NEVER COMMIT THESE ───────────────────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# Keep only the example files (no real values)
!.env.example

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Build output ──────────────────────────────────────────────────────────────
dist/
build/
.vite/

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Misc ─────────────────────────────────────────────────────────────────────
.cache/
coverage/
